rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function hasOnlyKeys(data, allowedKeys) {
      return data.keys().hasOnly(allowedKeys);
    }

    function hasAllKeys(data, requiredKeys) {
      return data.keys().hasAll(requiredKeys);
    }

    function optionalString(value) {
      return value == null || value is string;
    }

    function optionalInt(value) {
      return value == null || value is int;
    }

    function levelForXp(xp) {
      return ((xp - (xp % 200)) / 200) + 1;
    }

    function optionalTimestamp(value) {
      return value == null || value is timestamp;
    }

    function sameValue(field) {
      return request.resource.data[field] == resource.data[field];
    }

    function onlyTouches(allowedKeys) {
      return request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(allowedKeys);
    }

    function userKeys() {
      return [
        'uid',
        'name',
        'email',
        'photoUrl',
        'joinedAt',
        'lastLogin',
        'provider',
        'age',
        'currentLesson',
        'currentLessonStepIndex',
        'xp',
        'level',
        'lessonsCompleted',
        'totalLearningSeconds',
        'todayLessonCount',
        'todayLessonCountDate',
        'dailyStreak',
        'lastDailyLessonDate',
        'activityStreak',
        'lastActivityDateKey',
        'lastDevice',
        'appVersion',
        'timezone',
        'timezoneOffsetMinutes',
        'updatedAt'
      ];
    }

    function lessonProgressKeys() {
      return [
        'lessonId',
        'courseId',
        'chapterId',
        'globalLessonNumber',
        'startedAt',
        'lastActiveAt',
        'completedAt',
        'isCompleted',
        'completedCount'
      ];
    }

    function metadataUpdateKeys() {
      return [
        'name',
        'email',
        'photoUrl',
        'provider',
        'age',
        'lastDevice',
        'appVersion',
        'timezone',
        'timezoneOffsetMinutes',
        'lastLogin',
        'updatedAt'
      ];
    }

    function resumeKeys() {
      return [
        'currentLessonStepIndex',
        'updatedAt'
      ];
    }

    function progressionSummaryKeys() {
      return [
        'currentLesson',
        'currentLessonStepIndex',
        'xp',
        'lessonsCompleted',
        'todayLessonCount',
        'todayLessonCountDate',
        'dailyStreak',
        'lastDailyLessonDate',
        'activityStreak',
        'lastActivityDateKey',
        'updatedAt'
      ];
    }

    function existingIntOrDefault(field, fallback) {
      return resource.data.keys().hasAll([field]) &&
          resource.data[field] is int
          ? resource.data[field]
          : fallback;
    }

    function existingStringOrDefault(field, fallback) {
      return resource.data.keys().hasAll([field]) &&
          resource.data[field] is string
          ? resource.data[field]
          : fallback;
    }

    function existingTimestampOrNull(field) {
      return resource.data.keys().hasAll([field]) &&
          resource.data[field] is timestamp
          ? resource.data[field]
          : null;
    }

    function needsSchemaRepair() {
      return !resource.data.keys().hasAll(userKeys()) ||
          !(resource.data.currentLesson is int) ||
          !(resource.data.currentLessonStepIndex is int) ||
          !(resource.data.xp is int) ||
          !(resource.data.level is int) ||
          !(resource.data.lessonsCompleted is int) ||
          !(resource.data.totalLearningSeconds is int) ||
          !(resource.data.todayLessonCount is int) ||
          !(resource.data.dailyStreak is int) ||
          !(resource.data.activityStreak is int);
    }

    function validLegacyIntValue(field, fallback) {
      return (
          resource.data.keys().hasAll([field]) &&
          resource.data[field] is int &&
          request.resource.data[field] == resource.data[field]
        ) || (
          resource.data.keys().hasAll([field]) &&
          resource.data[field] is string &&
          resource.data[field].matches('^-?[0-9]+$') &&
          request.resource.data[field].toString() == resource.data[field]
        ) || (
          !(
            resource.data.keys().hasAll([field]) &&
            (
              resource.data[field] is int ||
              (
                resource.data[field] is string &&
                resource.data[field].matches('^-?[0-9]+$')
              )
            )
          ) &&
          request.resource.data[field] == fallback
        );
    }

    function validRequiredTimestampRepair(field) {
      return (
          resource.data.keys().hasAll([field]) &&
          resource.data[field] is timestamp &&
          request.resource.data[field] == resource.data[field]
        ) || (
          !(
            resource.data.keys().hasAll([field]) &&
            resource.data[field] is timestamp
          ) &&
          request.resource.data[field] is timestamp
        );
    }

    function validUserDocument(userId) {
      return hasOnlyKeys(request.resource.data, userKeys()) &&
          hasAllKeys(request.resource.data, userKeys()) &&
          request.resource.data.uid == userId &&
          optionalString(request.resource.data.name) &&
          optionalString(request.resource.data.email) &&
          optionalString(request.resource.data.photoUrl) &&
          request.resource.data.joinedAt is timestamp &&
          request.resource.data.currentLesson is int &&
          request.resource.data.currentLesson >= 1 &&
          request.resource.data.currentLessonStepIndex is int &&
          request.resource.data.currentLessonStepIndex >= 0 &&
          request.resource.data.xp is int &&
          request.resource.data.xp >= 0 &&
          request.resource.data.level is int &&
          request.resource.data.level == levelForXp(request.resource.data.xp) &&
          request.resource.data.lessonsCompleted is int &&
          request.resource.data.lessonsCompleted >= 0 &&
          request.resource.data.totalLearningSeconds is int &&
          request.resource.data.totalLearningSeconds >= 0 &&
          request.resource.data.todayLessonCount is int &&
          request.resource.data.todayLessonCount >= 0 &&
          optionalString(request.resource.data.todayLessonCountDate) &&
          request.resource.data.dailyStreak is int &&
          request.resource.data.dailyStreak >= 0 &&
          optionalString(request.resource.data.lastDailyLessonDate) &&
          request.resource.data.activityStreak is int &&
          request.resource.data.activityStreak >= 0 &&
          optionalString(request.resource.data.lastActivityDateKey) &&
          optionalInt(request.resource.data.age) &&
          optionalString(request.resource.data.provider) &&
          optionalString(request.resource.data.lastDevice) &&
          optionalString(request.resource.data.appVersion) &&
          optionalString(request.resource.data.timezone) &&
          optionalInt(request.resource.data.timezoneOffsetMinutes) &&
          optionalTimestamp(request.resource.data.lastLogin) &&
          optionalTimestamp(request.resource.data.updatedAt);
    }

    function validNewUserDocument(userId) {
      return validUserDocument(userId) &&
          request.resource.data.currentLesson == 1 &&
          request.resource.data.currentLessonStepIndex == 0 &&
          request.resource.data.xp == 0 &&
          request.resource.data.level == 1 &&
          request.resource.data.lessonsCompleted == 0 &&
          request.resource.data.totalLearningSeconds == 0 &&
          request.resource.data.todayLessonCount == 0 &&
          request.resource.data.todayLessonCountDate == null &&
          request.resource.data.dailyStreak == 0 &&
          request.resource.data.lastDailyLessonDate == null &&
          request.resource.data.activityStreak == 0 &&
          request.resource.data.lastActivityDateKey == null &&
          request.resource.data.age is int;
    }

    function validMetadataUpdate() {
      return validUserDocument(request.auth.uid) &&
          onlyTouches(metadataUpdateKeys()) &&
          sameValue('uid') &&
          sameValue('joinedAt') &&
          sameValue('currentLesson') &&
          sameValue('currentLessonStepIndex') &&
          sameValue('xp') &&
          sameValue('level') &&
          sameValue('lessonsCompleted') &&
          sameValue('totalLearningSeconds') &&
          sameValue('todayLessonCount') &&
          sameValue('todayLessonCountDate') &&
          sameValue('dailyStreak') &&
          sameValue('lastDailyLessonDate') &&
          sameValue('activityStreak') &&
          sameValue('lastActivityDateKey');
    }

    function validLegacySchemaRepair(userId) {
      return validUserDocument(userId) &&
          needsSchemaRepair() &&
          request.resource.data.uid == userId &&
          validRequiredTimestampRepair('joinedAt') &&
          validLegacyIntValue('currentLesson', 1) &&
          validLegacyIntValue('currentLessonStepIndex', 0) &&
          validLegacyIntValue('xp', 0) &&
          request.resource.data.level == levelForXp(request.resource.data.xp) &&
          validLegacyIntValue('lessonsCompleted', 0) &&
          validLegacyIntValue('totalLearningSeconds', 0) &&
          validLegacyIntValue('todayLessonCount', 0) &&
          (
            request.resource.data.todayLessonCountDate ==
                existingStringOrDefault('todayLessonCountDate', null) ||
            request.resource.data.todayLessonCountDate == null
          ) &&
          validLegacyIntValue('dailyStreak', 0) &&
          (
            request.resource.data.lastDailyLessonDate ==
                existingStringOrDefault('lastDailyLessonDate', null) ||
            request.resource.data.lastDailyLessonDate == null
          ) &&
          validLegacyIntValue('activityStreak', 0) &&
          (
            request.resource.data.lastActivityDateKey ==
                existingStringOrDefault('lastActivityDateKey', null) ||
            request.resource.data.lastActivityDateKey == null
          ) &&
          (
            request.resource.data.age is int ||
            request.resource.data.age == null
          );
    }

    function validResumeUpdate() {
      return validUserDocument(request.auth.uid) &&
          onlyTouches(resumeKeys()) &&
          sameValue('uid') &&
          sameValue('joinedAt') &&
          sameValue('currentLesson') &&
          sameValue('xp') &&
          sameValue('level') &&
          sameValue('lessonsCompleted') &&
          sameValue('totalLearningSeconds') &&
          sameValue('todayLessonCount') &&
          sameValue('todayLessonCountDate') &&
          sameValue('dailyStreak') &&
          sameValue('lastDailyLessonDate') &&
          sameValue('activityStreak') &&
          sameValue('lastActivityDateKey') &&
          request.resource.data.currentLessonStepIndex is int &&
          request.resource.data.currentLessonStepIndex >= 0;
    }

    function validProgressionSummaryUpdate() {
      let sameDay = request.resource.data.todayLessonCountDate ==
          resource.data.todayLessonCountDate;
      let isNewDay = request.resource.data.todayLessonCountDate !=
          resource.data.todayLessonCountDate;

      return validUserDocument(request.auth.uid) &&
          onlyTouches(progressionSummaryKeys()) &&
          sameValue('uid') &&
          sameValue('joinedAt') &&
          sameValue('name') &&
          sameValue('email') &&
          sameValue('photoUrl') &&
          sameValue('provider') &&
          sameValue('age') &&
          sameValue('lastDevice') &&
          sameValue('appVersion') &&
          sameValue('timezone') &&
          sameValue('timezoneOffsetMinutes') &&
          sameValue('lastLogin') &&
          sameValue('level') &&
          sameValue('totalLearningSeconds') &&
          sameValue('activityStreak') &&
          sameValue('lastActivityDateKey') &&
          request.resource.data.lessonsCompleted ==
              resource.data.lessonsCompleted + 1 &&
          request.resource.data.xp == resource.data.xp + 50 &&
          request.resource.data.currentLesson >= resource.data.currentLesson &&
          request.resource.data.currentLesson <= resource.data.currentLesson + 1 &&
          request.resource.data.currentLessonStepIndex == 0 &&
          (
            (
              sameDay &&
              request.resource.data.todayLessonCount ==
                  resource.data.todayLessonCount + 1 &&
              request.resource.data.dailyStreak == resource.data.dailyStreak &&
              request.resource.data.lastDailyLessonDate ==
                  resource.data.lastDailyLessonDate
            ) ||
            (
              isNewDay &&
              request.resource.data.todayLessonCount == 1 &&
              request.resource.data.lastDailyLessonDate ==
                  request.resource.data.todayLessonCountDate &&
              (
                request.resource.data.dailyStreak == 1 ||
                request.resource.data.dailyStreak ==
                    resource.data.dailyStreak + 1
              )
            )
          );
    }

    function validLessonProgressDocument(lessonId) {
      return hasOnlyKeys(request.resource.data, lessonProgressKeys()) &&
          hasAllKeys(request.resource.data, lessonProgressKeys()) &&
          request.resource.data.lessonId == lessonId &&
          request.resource.data.courseId is string &&
          request.resource.data.chapterId is string &&
          request.resource.data.globalLessonNumber is int &&
          request.resource.data.globalLessonNumber >= 1 &&
          optionalTimestamp(request.resource.data.startedAt) &&
          optionalTimestamp(request.resource.data.lastActiveAt) &&
          optionalTimestamp(request.resource.data.completedAt) &&
          request.resource.data.isCompleted is bool &&
          request.resource.data.completedCount is int &&
          request.resource.data.completedCount >= 0;
    }

    function validLessonStart(lessonId) {
      return validLessonProgressDocument(lessonId) &&
          request.resource.data.startedAt is timestamp &&
          request.resource.data.lastActiveAt is timestamp &&
          request.resource.data.completedAt == null &&
          request.resource.data.isCompleted == false &&
          request.resource.data.completedCount == 0;
    }

    function validLessonActivityUpdate() {
      return validLessonProgressDocument(resource.data.lessonId) &&
          onlyTouches(['lastActiveAt']) &&
          sameValue('lessonId') &&
          sameValue('courseId') &&
          sameValue('chapterId') &&
          sameValue('globalLessonNumber') &&
          sameValue('startedAt') &&
          sameValue('completedAt') &&
          sameValue('isCompleted') &&
          sameValue('completedCount') &&
          request.resource.data.lastActiveAt is timestamp;
    }

    function validLessonCompletionUpdate() {
      return validLessonProgressDocument(resource.data.lessonId) &&
          onlyTouches([
            'lastActiveAt',
            'completedAt',
            'isCompleted',
            'completedCount'
          ]) &&
          sameValue('lessonId') &&
          sameValue('courseId') &&
          sameValue('chapterId') &&
          sameValue('globalLessonNumber') &&
          sameValue('startedAt') &&
          resource.data.isCompleted == false &&
          request.resource.data.isCompleted == true &&
          request.resource.data.completedAt is timestamp &&
          request.resource.data.lastActiveAt is timestamp &&
          request.resource.data.completedCount == resource.data.completedCount + 1;
    }

    function validLessonReplayUpdate() {
      return validLessonProgressDocument(resource.data.lessonId) &&
          onlyTouches([
            'lastActiveAt',
            'completedCount'
          ]) &&
          sameValue('lessonId') &&
          sameValue('courseId') &&
          sameValue('chapterId') &&
          sameValue('globalLessonNumber') &&
          sameValue('startedAt') &&
          sameValue('completedAt') &&
          sameValue('isCompleted') &&
          resource.data.isCompleted == true &&
          request.resource.data.completedCount == resource.data.completedCount + 1 &&
          request.resource.data.lastActiveAt is timestamp;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);

      allow create: if isOwner(userId) &&
          validNewUserDocument(userId);

      allow update: if isOwner(userId) &&
          (validMetadataUpdate() || validLegacySchemaRepair(userId));

      match /lessonProgress/{lessonId} {
        allow read: if isOwner(userId);
      }

      match /activityDays/{dateKey} {
        allow read: if isOwner(userId);
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
